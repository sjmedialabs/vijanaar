## Server environment variables
## Copy to `server/.env` for local dev (do NOT commit real secrets).

# Server
PORT=5000
MONGO_URI=mongodb://localhost:27017/mydatabase
JWT_SECRET=change-me
FRONTEND_URL=http://localhost:3000
BASE_URL=http://localhost:5000

## Email (recommended): generic SMTP
# Option A: single URL (preferred)
# SMTP_URL=smtp://USER:PASS@smtp.gmail.com:587

# Option B: host/port
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Vijanaar <your-email@gmail.com>"

## Email receivers
ENQUIRY_RECEIVER_EMAIL=admin@yourdomain.com
CONTACT_US_RECEIVER_EMAIL=admin@yourdomain.com

## Legacy (supported, but prefer SMTP_* above)
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password
